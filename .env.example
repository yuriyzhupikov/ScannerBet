NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://mdds:mdds_dev_password@postgres:5432/mdds?schema=public
REDIS_HOST=redis
REDIS_PORT=6379

ADMIN_API_TOKEN=dev-admin-token
DISCREPANCY_THRESHOLD_BPS=50
DISCREPANCY_WINDOW_SECONDS=120
DEFAULT_SPREAD_THRESHOLD_PCT=0.035
SIGNAL_WINDOW_SECONDS=120
RAW_PAYLOAD_RETENTION_DAYS=7

INGESTION_CONCURRENCY=8
SOURCE_PULL_CRON=*/5 * * * * *
ALLOWED_SOURCE_HOSTS=partner-a.internal.example,partner-b.internal.example
SOURCE_API_KEY_PARTNER_A=replace_with_secret_manager
WEBHOOK_SECRET_PARTNER_A=replace_with_secret_manager
OTEL_SERVICE_NAME=authorized-market-data-scanner
LOG_LEVEL=info

# Optional. Must point to localhost/127.0.0.1/::1 only.
DEMO_FRONT_FEED_URL=
